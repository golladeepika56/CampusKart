# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
# Use a persistent MongoDB instance for data that survives restarts.
# Example local MongoDB URI:
# MONGO_URI=mongodb://127.0.0.1:27017/campuskart
# If you want to use Atlas, put your Atlas URI here.
# If your network blocks SRV lookups, use Atlas' standard connection string instead of mongodb+srv.
# If no URI is configured or Atlas fails, the server will try local MongoDB and then fall back to an in-memory database.
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/campuskart?retryWrites=true&w=majority
# Optionally override DNS servers for Atlas SRV resolution (e.g. 8.8.8.8,1.1.1.1)
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/campuskart

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Campus email restriction — only users with this domain can register
ALLOWED_EMAIL_DOMAIN=@yourcollege.edu.in

# Email (Nodemailer - for OTP + notifications). Example uses Gmail SMTP with an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Image uploads are stored locally in the server's uploads/ folder

# Razorpay (payments) - use test mode keys from the Razorpay dashboard
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret
